rules_version = '2';

// =============================================================================
// Swing Terminal — Firestore Security Rules
// -----------------------------------------------------------------------------
// Two-layer access model:
//
//   /marketData/{date}/signals/{signalId}
//   /marketData/{date}/regime/{marketId}
//     READ:  any authenticated user, including via collection-group queries
//     WRITE: server only (Firebase Admin SDK via GitHub Actions cron)
//
//   /users/{uid}/**
//     READ + WRITE: only when request.auth.uid == uid
//
// IMPORTANT: collection-group queries require a top-level wildcard match. The
// History view uses `collectionGroup(db, 'signals').orderBy('signalTs', ...)`
// which Firestore evaluates against a recursive-wildcard rule, NOT the nested
// /marketData/{date}/signals/{id} rule. Both rules are kept for clarity:
//   - The `{path=**}/signals/{id}` rule authorises collection-group reads.
//   - The nested rule documents the intended location of these docs.
//
// After editing this file, deploy with:
//   firebase deploy --only firestore:rules
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // -----------------------------------------------------------------------
    // Collection-group reads for shared market data.
    // The `{path=**}` recursive wildcard is what makes
    // `collectionGroup(db, 'signals')` work — without this, the History view
    // gets "Missing or insufficient permissions" even though the nested
    // /marketData/{date}/signals/{id} rule would allow direct reads.
    // -----------------------------------------------------------------------
    match /{path=**}/signals/{signalId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /{path=**}/regime/{regimeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Shared market data — direct path rules (redundant with the wildcards
    // above, kept for documentation of intended location + explicit write deny)
    // -----------------------------------------------------------------------
    match /marketData/{dateBucket} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Per-user private data
    // -----------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /enteredTrades/{tradeId} {
        allow read, write: if isOwner(uid);
      }

      match /watchlist/{tickerId} {
        allow read, write: if isOwner(uid);
      }

      match /preferences/{prefId} {
        allow read, write: if isOwner(uid);
      }

      // FCM push notification tokens — written by the client when the user
      // enables notifications in Settings. Cron worker reads via Admin SDK
      // (bypasses these rules), so only the user's own writes need authorising.
      match /fcmTokens/{token} {
        allow read, write: if isOwner(uid);
      }

      // Automation config (/users/{uid}/automation/config). Holds the user's
      // auto-trade rules AND broker API credentials, so it must be readable only
      // by the owner. The execution worker reads it via the Admin SDK (bypasses
      // these rules). Never broaden this read rule.
      match /automation/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Auto-trade order journal (/users/{uid}/autoOrders/{clientOrderId}).
      // Written by the execution worker via the Admin SDK (bypasses rules); the
      // owner may READ their own order history. Clients must not write here.
      match /autoOrders/{orderId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Daily account-equity snapshots (/users/{uid}/autoEquity/{date}) for the
      // equity curve. Written by the worker (Admin); owner reads. No client write.
      match /autoEquity/{date} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // -----------------------------------------------------------------------
    // Publicly-readable, server-written config (optional)
    // -----------------------------------------------------------------------
    match /publicConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
