# Firebase Web SDK config. These values are PUBLIC by design — Firebase Auth + Firestore
# enforce security via Auth state + Security Rules, not by hiding these keys.
# Copy this file to `.env.local` for local dev, and set the same values as repo secrets
# (Settings → Secrets and variables → Actions) named VITE_FIREBASE_* for the deploy workflow.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The base path the app is served from. Defaults to '/swing-stocks/' in production
# (set by vite.config.js); only override if you fork to a differently-named repo.
# VITE_APP_BASE=/swing-stocks/
